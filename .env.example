# Copy to .env.local (gitignored) and fill in. Also set these in Vercel →
# Project → Settings → Environment Variables for production.

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ──────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
# Verified sender for transactional/alert emails, e.g. "McPrime <notifications@yourdomain.com>"
NOTIFY_FROM_EMAIL=

# ── Cloudflare R2 ───────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
# Optional soft storage quota shown in the File Vault meter (GB).
NEXT_PUBLIC_STORAGE_QUOTA_GB=25

# ── Web Push (device notifications) ─────────────────────────
# Generate with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Must equal VAPID_PUBLIC_KEY (exposed to the browser to subscribe).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# A mailto: or https: contact for the push service.
VAPID_SUBJECT=mailto:notifications@yourdomain.com

# ── SMS (Twilio) — optional, for cellphone alerts ───────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
